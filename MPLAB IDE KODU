// Servo aç?s?n? ayarlayan fonksiyon
void set_servo_angle(uint8_t angle) {
if (angle > 180) angle = 180;
// Standart Servo hesaplamas?:
// 0 derece -> ~1.0 ms pulse -> 625 tick (Bazı servolarda bu 0.5ms yani 312 tick olabilir)
// 180 derece -> ~2.0 ms pulse -> 1250 tick (Bazı servolarda bu 2.5ms yani 1562 tick olabilir)
// E?er servonuz tam 180 dönmüyorsa 625 ve 1250 de?erleriyle oynayabilirsiniz.
uint32_t min_tick = 625;
uint32_t max_tick = 1250;
uint16_t duty_ticks = min_tick + ((uint32_t)angle * (max_tick - min_tick)) / 180;
OC1RS = duty_ticks;
}
void trigger_ultrasonic() {
trigger = 1;
DELAY_US(15);
trigger = 0;
